# ──────────────────────────────────────────────────────────────────────────────
# .env.example – copy to .env and fill in your values before opening any
#                dev container.  The .env file is loaded automatically by the
#                container via runArgs in devcontainer.json.
#
# NEVER commit the .env file – it is listed in .gitignore.
# ──────────────────────────────────────────────────────────────────────────────

# ── GitHub ────────────────────────────────────────────────────────────────────
# Personal Access Token used by the GitHub CLI, the GitHub MCP server, and
# GitHub Copilot CLI.  Requires scopes: repo, read:org, workflow.
GITHUB_TOKEN=your_github_token_here
GITHUB_PERSONAL_ACCESS_TOKEN=your_github_pat_here

# ── MCP – Context7 ────────────────────────────────────────────────────────────
# No additional keys required; the server uses public library index.

# ── MCP – Chrome DevTools ─────────────────────────────────────────────────────
# Optional: set a custom remote debugging port (default: 9222)
# CHROME_DEBUGGING_PORT=9222
